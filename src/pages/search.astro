---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Search" description="Search tracks and stories on titi.work" showPlayer={false}>
  <section class="max-w-2xl mx-auto px-6 pt-32 min-h-screen">
    <h1 class="text-3xl font-bold mb-8">Search</h1>

    <div id="search-container" class="hidden">
      <p class="text-white/40 text-sm mb-4">Type to search tracks and stories...</p>
      <input
        type="text"
        id="search-input"
        placeholder="Search tracks, stories..."
        class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-white placeholder-white/30 focus:outline-none focus:border-white/30 transition-colors"
      />
      <div id="search-results" class="mt-6 space-y-3" />
    </div>

    <div id="search-not-built">
      <div class="bg-white/5 border border-white/10 rounded-xl p-8 text-center">
        <p class="text-white/40 mb-2">Search index not yet built.</p>
        <p class="text-white/20 text-sm">Run <code class="bg-white/5 px-2 py-1 rounded">npm run build</code> first, then <code class="bg-white/5 px-2 py-1 rounded">npx pagefind --site dist</code> to generate the search index.</p>
      </div>
    </div>
  </section>
</BaseLayout>

<script is:inline>
  window.addEventListener('DOMContentLoaded', async function() {
    var container = document.getElementById('search-container');
    var notBuilt = document.getElementById('search-not-built');
    var input = document.getElementById('search-input');
    var results = document.getElementById('search-results');
    if (!container || !input || !results) return;

    try {
      var pagefind = await import('/pagefind/pagefind.js');
      container.classList.remove('hidden');
      if (notBuilt) notBuilt.remove();

      input.addEventListener('input', async function() {
        var query = input.value.trim();
        if (!query) {
          results.innerHTML = '';
          return;
        }
        var res = await pagefind.search(query);
        if (res.results.length === 0) {
          results.innerHTML = '<p class="text-white/40 text-sm">No results found.</p>';
          return;
        }
        results.innerHTML = res.results.slice(0, 10).map(function(r) {
          return '<a href="' + r.url + '" class="block p-4 bg-white/5 hover:bg-white/10 rounded-xl transition-colors border border-transparent hover:border-white/10"><p class="text-white/80 font-medium">' + (r.meta && r.meta.title ? r.meta.title : 'Page') + '</p></a>';
        }).join('');
      });
    } catch(e) {
      // Pagefind not available — show not-built message
    }
  });
</script>
