---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
const stories = await getCollection('stories');
const sorted = stories.sort((a, b) => a.data.date.localeCompare(b.data.date));
---

<BaseLayout
  title="About"
  description="About titi.work — who we are and why we make music."
  showPlayer={false}
>
  <!-- Hero -->
  <section class="min-h-[60vh] flex flex-col items-center justify-center text-center px-6 pt-20">
    <div class="w-24 h-24 rounded-full bg-gradient-to-br from-pink-500 to-purple-600 mb-8 flex items-center justify-center text-3xl">
      ♪
    </div>
    <h1 class="text-4xl md:text-5xl font-bold mb-4">About</h1>
    <p class="text-white/50 max-w-lg text-lg leading-relaxed">
      We make music because silence is overrated. Based between Vienna and London, we write songs about cats, code, and the strange beauty of everyday life.
    </p>
  </section>

  <!-- Stories -->
  <section class="max-w-3xl mx-auto px-6 py-16">
    <h2 class="text-2xl font-bold mb-8 flex items-center gap-3">
      <span class="text-pink-400">♥</span> Stories
    </h2>

    <div class="space-y-6">
      {sorted.map(story => (
        <a href={`/stories/${story.id}`} class="block group">
          <div class="border border-white/5 rounded-2xl p-6 hover:border-white/15 hover:bg-white/[0.02] transition-all">
            <div class="flex items-center justify-between mb-2">
              <h3 class="text-lg font-medium text-white/80 group-hover:text-white transition-colors">
                {story.data.title}
              </h3>
              <span class="text-white/20 text-xs">{story.data.date}</span>
            </div>
            {story.data.description && (
              <p class="text-white/40 text-sm">{story.data.description}</p>
            )}
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- Contact -->
  <section class="max-w-3xl mx-auto px-6 py-12 border-t border-white/5">
    <h2 class="text-xl font-bold mb-6">Get in Touch</h2>
    <div class="flex flex-wrap gap-4">
      <a href="https://github.com" target="_blank" rel="noopener" class="px-4 py-2 border border-white/10 rounded-full text-white/50 hover:text-white hover:border-white/30 text-sm transition-all">
        GitHub
      </a>
      <a href="https://x.com" target="_blank" rel="noopener" class="px-4 py-2 border border-white/10 rounded-full text-white/50 hover:text-white hover:border-white/30 text-sm transition-all">
        X / Twitter
      </a>
      <a href="mailto:hello@titi.work" class="px-4 py-2 border border-white/10 rounded-full text-white/50 hover:text-white hover:border-white/30 text-sm transition-all">
        Email
      </a>
    </div>
  </section>
</BaseLayout>
