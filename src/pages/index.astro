---
import BaseLayout from '../layouts/BaseLayout.astro';
import TrackCard from '../components/TrackCard';
import Timeline from '../components/Timeline';
import { getCollection } from 'astro:content';

const tracks = await getCollection('tracks');
const timeline = await getCollection('timeline');

const sortedTracks = tracks.sort((a, b) => (a.data.order || 99) - (b.data.order || 99));
const featuredTracks = sortedTracks.filter(t => t.data.featured);
const allTracks = sortedTracks;
---

<BaseLayout
  title="titi.work"
  description="Music, stories, and the adventures of two cats navigating love and code across Vienna and London."
>
  <!-- Hero -->
  <section class="min-h-screen flex flex-col items-center justify-center text-center px-6 relative overflow-hidden pt-20 hero-glow">
    <!-- Animated background elements -->
    <div class="absolute inset-0 overflow-hidden pointer-events-none">
      <div class="absolute top-1/4 left-1/4 w-64 h-64 bg-purple-500/10 rounded-full blur-3xl animate-pulse" />
      <div class="absolute bottom-1/4 right-1/4 w-96 h-96 bg-pink-500/10 rounded-full blur-3xl animate-pulse" style="animation-delay: 1s" />
    </div>

    <div class="relative z-10 max-w-2xl">
      <p class="text-purple-400 text-sm uppercase tracking-[0.3em] mb-6 animate-fade-in-up">Music & Stories</p>

      <!-- Main title with gradient -->
      <h1 class="text-5xl md:text-7xl font-bold mb-6 tracking-tight animate-fade-in-up" style="animation-delay: 0.1s">
        <span class="gradient-text">titi.work</span>
      </h1>

      <p class="text-gray-400 text-lg md:text-xl max-w-lg mx-auto mb-10 leading-relaxed animate-fade-in-up" style="animation-delay: 0.2s">
        Two cats, one shared playlist. Original compositions born from late nights, early mornings, and everything in between.
      </p>

      <!-- CTA buttons -->
      <div class="flex gap-4 justify-center flex-wrap animate-fade-in-up" style="animation-delay: 0.3s">
        <a href="#tracks" class="btn-gradient px-8 py-3.5 rounded-full flex items-center gap-2 group">
          <svg class="w-5 h-5 group-hover:scale-110 transition-transform" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
          Listen Now
        </a>
        <a href="/about" class="glass px-8 py-3.5 rounded-full text-gray-300 hover:text-white transition-all hover:bg-white/10">
          About Us
        </a>
      </div>

      <!-- Stats -->
      <div class="mt-16 flex gap-8 justify-center animate-fade-in-up" style="animation-delay: 0.4s">
        <div class="text-center">
          <p class="text-3xl font-bold gradient-text">{tracks.length}</p>
          <p class="text-gray-500 text-sm">Tracks</p>
        </div>
        <div class="w-px bg-gray-800" />
        <div class="text-center">
          <p class="text-3xl font-bold gradient-text">{featuredTracks.length}</p>
          <p class="text-gray-500 text-sm">Featured</p>
        </div>
        <div class="w-px bg-gray-800" />
        <div class="text-center">
          <p class="text-3xl font-bold gradient-text">{timeline.length}</p>
          <p class="text-gray-500 text-sm">Memories</p>
        </div>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-10 left-1/2 -translate-x-1/2 animate-scroll">
      <div class="w-6 h-10 rounded-full border-2 border-white/20 flex justify-center pt-2">
        <div class="w-1.5 h-3 bg-white/40 rounded-full" />
      </div>
    </div>
  </section>

  <!-- Signature Tracks -->
  <section id="tracks" class="max-w-5xl mx-auto px-6 py-20">
    <div class="mb-8">
      <h2 class="section-title text-2xl font-bold text-white mb-2">Signature Tracks</h2>
      <p class="text-gray-500">Handpicked favorites. Hit play and let them carry you somewhere.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 stagger-children">
      {featuredTracks.map((track) => (
        <TrackCard
          client:load
          id={track.id}
          title={track.data.title}
          coverColor={track.data.coverColor}
          duration={track.data.duration}
          audioFile={`/music/${track.data.audioFile}`}
          featured={true}
        />
      ))}
    </div>
  </section>

  <!-- All Tracks -->
  <section class="max-w-5xl mx-auto px-6 py-10">
    <div class="mb-8">
      <h2 class="section-title text-2xl font-bold text-white mb-2">All Tracks</h2>
      <p class="text-gray-500">{allTracks.length} compositions and counting.</p>
    </div>

    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5 gap-3 stagger-children">
      {allTracks.map((track) => (
        <TrackCard
          client:load
          id={track.id}
          title={track.data.title}
          coverColor={track.data.coverColor}
          duration={track.data.duration}
          audioFile={`/music/${track.data.audioFile}`}
          featured={false}
        />
      ))}
    </div>
  </section>

  <!-- Timeline -->
  <section class="max-w-5xl mx-auto px-6 py-20">
    <div class="mb-12">
      <h2 class="section-title text-2xl font-bold text-white mb-2">Timeline</h2>
      <p class="text-gray-500">A few moments worth remembering.</p>
    </div>

    <Timeline client:load events={
      timeline.map(t => ({
        id: t.id,
        date: t.data.date,
        title: t.data.title,
        description: t.data.description,
        icon: t.data.icon,
        linkedTrack: t.data.linkedTrack,
      }))
    } />
  </section>

  <!-- Footer -->
  <footer class="max-w-5xl mx-auto px-6 py-12 border-t border-white/5 text-center">
    <p class="text-white/20 text-sm">
      &copy; {new Date().getFullYear()} titi.work &middot; Made with <span class="text-purple-400">&hearts;</span> and late nights
    </p>
    <div class="flex justify-center gap-6 mt-4">
      <a href="/rss.xml" class="text-white/30 hover:text-white/60 text-xs transition-colors">RSS</a>
      <a href="/about" class="text-white/30 hover:text-white/60 text-xs transition-colors">About</a>
    </div>
  </footer>
</BaseLayout>
