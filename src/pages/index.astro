---
import BaseLayout from '../layouts/BaseLayout.astro';
import TrackCard from '../components/TrackCard';
import Timeline from '../components/Timeline';
import { getCollection } from 'astro:content';
import { Play } from 'lucide-react';

const tracks = await getCollection('tracks');
const timeline = await getCollection('timeline');

const sortedTracks = tracks.sort((a, b) => (a.data.order || 99) - (b.data.order || 99));
const featuredTracks = sortedTracks.filter(t => t.data.featured);
const allTracks = sortedTracks;

const heroTrack = featuredTracks[0] || allTracks[0];
---

<BaseLayout
  title="titi.work"
  description="Music, stories, and the adventures of two cats navigating love and code across Vienna and London."
>
  <!-- Hero Section -->
  {heroTrack && (
    <section class="max-w-5xl mx-auto px-6 pt-8">
      <div class="hero-section relative group cursor-pointer">
        <!-- Background -->
        <div class="absolute inset-0">
          <img
            src="https://lh3.googleusercontent.com/aida-public/AB6AXuCgtOZokyfW-5iyT7eX3l8NY76ryhn_alBS73FGb5OwQ4Da4Vf5ragbLvEeiRW3zZLPR4kQbSA7bF5klocofwBe67MJPg5Sp5U-DYVY37gjbF8-XdmDsnz7e8-qf3as2cCtqpK-kXWGHeUb6BQh-NzsG8klyB61WpDEUl40kPsZoggBMwagSz3dUcQZ3eOjwN4ytx8HJtGRSXYblhqN8YEICLWO_GI4xYr_mGpLlH5mOKC4Pjr7VJTmgBqTOXfYB_KDFb5HY13JfJfH"
            alt="Hero Background"
            class="w-full h-full object-cover scale-105"
            referrerPolicy="no-referrer"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-[#131313] via-[#131313]/50 to-transparent" />
        </div>

        <!-- Content -->
        <div class="absolute inset-0 p-8 md:p-12 flex flex-col justify-end gap-6">
          <motion-div class="space-y-4">
            <span class="badge">New Entry</span>
            <h2 class="text-5xl md:text-7xl font-black leading-none tracking-tighter max-w-2xl">
              {heroTrack.data.title}
            </h2>
            <p class="text-[#dcc0bd] text-lg max-w-md font-light italic">
              A soulful homage to the feline spirit that guides this sonic journey.
            </p>
          </motion-div>

          <div class="flex items-center gap-4">
            <button
              class="hero-play-btn w-16 h-16 rounded-full bg-gradient-primary text-[#60130f] flex items-center justify-center shadow-2xl hover:scale-105 active:scale-95 transition-all"
              data-id={heroTrack.id}
              data-title={heroTrack.data.title}
              data-cover={heroTrack.data.coverColor}
              data-duration={heroTrack.data.duration}
              data-file={heroTrack.data.audioFile}
            >
              <Play size={32} fill="currentColor" className="ml-1" />
            </button>
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- All Tracks -->
  <section class="max-w-5xl mx-auto px-6 py-12">
    <div class="flex justify-between items-end mb-8">
      <h3 class="section-title">All Tracks</h3>
      <span class="text-[10px] uppercase tracking-widest font-bold text-[#dcc0bd]">
        {allTracks.length} Archived Items
      </span>
    </div>

    <div class="space-y-2">
      {allTracks.map((track, index) => (
        <TrackCard
          client:load
          id={track.id}
          title={track.data.title}
          coverColor={track.data.coverColor}
          duration={track.data.duration}
          audioFile={track.data.audioFile}
          featured={track.data.featured}
          index={index + 1}
        />
      ))}
    </div>
  </section>

  <!-- Timeline -->
  <section class="max-w-5xl mx-auto px-6 py-8">
    <div class="mb-8">
      <h3 class="section-title">Timeline</h3>
    </div>

    <Timeline client:load events={
      timeline.map(t => ({
        id: t.id,
        date: t.data.date,
        title: t.data.title,
        description: t.data.description,
        icon: t.data.icon,
        linkedTrack: t.data.linkedTrack,
      }))
    } />
  </section>

  <!-- Footer -->
  <footer class="max-w-5xl mx-auto px-6 py-12 border-t border-white/5 text-center">
    <p class="text-white/20 text-sm">
      &copy; {new Date().getFullYear()} titi.work &middot; Made with <span class="text-[#ffb4aa]">&hearts;</span> and late nights
    </p>
  </footer>
</BaseLayout>

<script>
  // Hero play button handler
  document.addEventListener('DOMContentLoaded', () => {
    const heroBtn = document.querySelector('.hero-play-btn');
    if (!heroBtn) return;

    heroBtn.addEventListener('click', (e) => {
      const btn = e.currentTarget as HTMLElement;
      const track = {
        id: btn.dataset.id!,
        title: btn.dataset.title!,
        audioFile: btn.dataset.file!,
        coverColor: btn.dataset.cover!,
        duration: Number(btn.dataset.duration),
      };
      window.dispatchEvent(new CustomEvent('play-track', { detail: track }));
    });
  });
</script>
