---
import BaseLayout from '../layouts/BaseLayout.astro';
import TrackCard from '../components/TrackCard';
import Timeline from '../components/Timeline';
import { getCollection } from 'astro:content';
import { useAudio } from '../contexts/AudioContext';

const tracks = await getCollection('tracks');
const timeline = await getCollection('timeline');

const sortedTracks = tracks.sort((a, b) => (a.data.order || 99) - (b.data.order || 99));
const featuredTracks = sortedTracks.filter(t => t.data.featured);
const allTracks = sortedTracks;
---

<BaseLayout
  title="titi.work"
  description="Music, stories, and the adventures of two cats navigating love and code across Vienna and London."
>
  <!-- Hero -->
  <section class="min-h-screen flex flex-col items-center justify-center text-center px-6 relative overflow-hidden">
    <!-- Ambient background with animated glow -->
    <div class="ambient-glow" aria-hidden="true"></div>

    <div class="relative z-10">
      <!-- Animated decorative elements -->
      <div class="absolute -top-20 left-1/2 -translate-x-1/2 w-1 h-32 bg-gradient-to-b from-[#d4789a]/30 to-transparent rounded-full" />

      <p class="text-[#d4789a] text-sm uppercase tracking-[0.3em] mb-6 animate-fade-in">♪ Music & Stories</p>

      <!-- Gradient title -->
      <h1 class="text-5xl md:text-7xl font-bold mb-6 tracking-tight">
        <span class="bg-gradient-to-r from-white via-[#d4789a] to-[#9b8ac4] bg-clip-text text-transparent">
          titi.work
        </span>
      </h1>

      <p class="text-white/60 text-lg md:text-xl max-w-lg mx-auto mb-10 leading-relaxed">
        Two cats, one shared playlist. Original compositions born from late nights, early mornings, and everything in between.
      </p>

      <!-- CTA buttons with hover effects -->
      <div class="flex gap-4 justify-center flex-wrap">
        <a href="#tracks" class="group px-8 py-3.5 bg-gradient-to-r from-[#d4789a] to-[#9b8ac4] text-white font-medium rounded-full hover:shadow-lg hover:shadow-purple-500/25 transition-all hover:scale-105 active:scale-95">
          <span class="flex items-center gap-2">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
            Listen Now
          </span>
        </a>
        <a href="/about" class="px-8 py-3.5 border border-white/20 text-white/70 rounded-full hover:border-white/40 hover:text-white hover:bg-white/5 transition-all">
          About Us
        </a>
      </div>

      <!-- Stats -->
      <div class="mt-16 flex gap-8 justify-center text-center">
        <div>
          <p class="text-2xl font-bold text-white">{tracks.length}</p>
          <p class="text-white/40 text-sm">Tracks</p>
        </div>
        <div class="w-px bg-white/10" />
        <div>
          <p class="text-2xl font-bold text-white">{featuredTracks.length}</p>
          <p class="text-white/40 text-sm">Featured</p>
        </div>
        <div class="w-px bg-white/10" />
        <div>
          <p class="text-2xl font-bold text-white">{timeline.length}</p>
          <p class="text-white/40 text-sm">Memories</p>
        </div>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-12 left-1/2 -translate-x-1/2 text-white/20">
      <div class="animate-bounce">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M12 5v14M5 12l7 7 7-7" />
        </svg>
      </div>
    </div>
  </section>

  <!-- Signature Tracks -->
  <section id="tracks" class="max-w-5xl mx-auto px-6 py-20">
    <div class="flex items-center gap-3 mb-2">
      <span class="text-pink-400">✦</span>
      <h2 class="text-2xl font-bold">Signature Tracks</h2>
    </div>
    <p class="text-white/40 mb-8">Handpicked favorites. Hit play and let them carry you somewhere.</p>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      {featuredTracks.map((track) => (
        <div class="track-wrapper" data-id={track.id} data-title={track.data.title} data-cover={track.data.coverColor} data-file={track.data.audioFile} data-duration={track.data.duration}>
          <TrackCard
            client:load
            id={track.id}
            title={track.data.title}
            coverColor={track.data.coverColor}
            duration={track.data.duration}
            featured={true}
          />
        </div>
      ))}
    </div>
  </section>

  <!-- All Tracks -->
  <section class="max-w-5xl mx-auto px-6 py-10">
    <div class="flex items-center gap-3 mb-2">
      <span class="text-white/20">◈</span>
      <h2 class="text-2xl font-bold">All Tracks</h2>
    </div>
    <p class="text-white/40 mb-8">{allTracks.length} compositions and counting.</p>

    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5 gap-3">
      {allTracks.map((track) => (
        <TrackCard
          client:load
          id={track.id}
          title={track.data.title}
          coverColor={track.data.coverColor}
          duration={track.data.duration}
          featured={false}
        />
      ))}
    </div>
  </section>

  <!-- Timeline -->
  <section class="max-w-5xl mx-auto px-6 py-20">
    <div class="flex items-center gap-3 mb-2">
      <span class="text-amber-400">♥</span>
      <h2 class="text-2xl font-bold">Timeline</h2>
    </div>
    <p class="text-white/40 mb-12">A few moments worth remembering.</p>

    <Timeline client:load events={
      timeline.map(t => ({
        id: t.id,
        date: t.data.date,
        title: t.data.title,
        description: t.data.description,
        icon: t.data.icon,
        linkedTrack: t.data.linkedTrack,
      }))
    } />
  </section>

  <!-- Footer -->
  <footer class="max-w-5xl mx-auto px-6 py-12 border-t border-white/5 text-center">
    <p class="text-white/20 text-sm">
      © {new Date().getFullYear()} titi.work · Made with ♪ and late nights
    </p>
    <div class="flex justify-center gap-6 mt-4">
      <a href="/rss.xml" class="text-white/30 hover:text-white/60 text-xs transition-colors">RSS</a>
      <a href="/about" class="text-white/30 hover:text-white/60 text-xs transition-colors">About</a>
    </div>
  </footer>
</BaseLayout>

<script>
  // Wire up TrackCard play buttons to AudioContext
  document.addEventListener('DOMContentLoaded', () => {
    const wrappers = document.querySelectorAll('.track-wrapper');
    wrappers.forEach(wrapper => {
      const el = wrapper as HTMLElement;
      const btn = el.querySelector('button');
      if (!btn) return;

      btn.addEventListener('click', () => {
        const track = {
          id: el.dataset.id!,
          title: el.dataset.title!,
          audioFile: el.dataset.file!,
          coverColor: el.dataset.cover!,
          duration: Number(el.dataset.duration),
        };

        // Dispatch custom event for AudioContext
        window.dispatchEvent(new CustomEvent('play-track', { detail: track }));
      });
    });
  });
</script>
