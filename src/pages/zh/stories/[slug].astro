---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const stories = await getCollection('stories');
  return stories.map(story => ({
    params: { slug: story.id },
    props: { story },
  }));
}

const { story } = Astro.props;
const { Content } = await render(story);
---

<BaseLayout title={story.data.title} description={story.data.description || story.data.title} type="article" lang="zh" showPlayer={false}>
  <article class="max-w-2xl mx-auto px-6 py-24">
    <a href="/zh/about" class="text-white/30 hover:text-white/60 text-sm mb-8 inline-flex items-center gap-2 transition-colors">
      ← 关于
    </a>
    <header class="mb-12">
      <p class="text-white/30 text-sm mb-3">{story.data.date}</p>
      <h1 class="text-3xl md:text-4xl font-bold">{story.data.titleZh || story.data.title}</h1>
    </header>
    <div class="prose prose-invert prose-p:text-white/70 prose-headings:text-white prose-a:text-pink-400 leading-relaxed">
      <Content />
    </div>
  </article>
</BaseLayout>
