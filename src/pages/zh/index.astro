---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TrackCard from '../../components/TrackCard';
import Timeline from '../../components/Timeline';
import { getCollection } from 'astro:content';

const tracks = await getCollection('tracks');
const timeline = await getCollection('timeline');
const sortedTracks = tracks.sort((a, b) => (a.data.order || 99) - (b.data.order || 99));
const featuredTracks = sortedTracks.filter(t => t.data.featured);
---

<BaseLayout title="titi.work" description="音乐与故事 — 两只猫的创作空间" lang="zh">
  <!-- Hero -->
  <section class="min-h-screen flex flex-col items-center justify-center text-center px-6">
    <div class="absolute inset-0 pointer-events-none">
      <div class="absolute top-1/4 left-1/4 w-96 h-96 bg-pink-500/10 rounded-full blur-3xl" />
      <div class="absolute bottom-1/4 right-1/4 w-96 h-96 bg-purple-500/10 rounded-full blur-3xl" />
    </div>

    <div class="relative z-10">
      <p class="text-white/30 text-sm uppercase tracking-[0.3em] mb-6">♪ 音乐与故事</p>
      <h1 class="text-5xl md:text-7xl font-bold mb-4 tracking-tight">
        titi<span class="text-pink-400">.</span>work
      </h1>
      <p class="text-white/50 text-lg md:text-xl max-w-md mx-auto mb-10 leading-relaxed">
        两只猫，一份共同播放列表。在深夜与清晨之间，创作关于猫、代码与生活的歌曲。
      </p>
      <div class="flex gap-4 justify-center">
        <a href="#tracks" class="px-8 py-3 bg-white text-black font-medium rounded-full hover:bg-white/90 transition-colors">
          开始聆听
        </a>
        <a href="/zh/about" class="px-8 py-3 border border-white/20 text-white/70 rounded-full hover:border-white/40 hover:text-white transition-colors">
          关于我们
        </a>
      </div>
    </div>
  </section>

  <!-- Signature Tracks -->
  <section id="tracks" class="max-w-5xl mx-auto px-6 py-20">
    <h2 class="text-2xl font-bold mb-2 flex items-center gap-3">
      <span class="text-pink-400">✦</span> 精选曲目
    </h2>
    <p class="text-white/40 mb-8">精心挑选的最爱。点击播放，让音乐带你远行。</p>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      {featuredTracks.map((track) => (
        <div class="track-wrapper" data-id={track.id} data-title={track.data.title} data-cover={track.data.coverColor} data-file={track.data.audioFile} data-duration={track.data.duration}>
          <TrackCard client:load id={track.id} title={track.data.title} coverColor={track.data.coverColor} duration={track.data.duration} featured={true} />
        </div>
      ))}
    </div>
  </section>

  <!-- All Tracks -->
  <section class="max-w-5xl mx-auto px-6 py-10">
    <h2 class="text-2xl font-bold mb-2 flex items-center gap-3">
      <span class="text-white/20">◈</span> 全部曲目
    </h2>
    <p class="text-white/40 mb-8">共 {sortedTracks.length} 首创作，持续增加中。</p>

    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5 gap-3">
      {sortedTracks.map((track) => (
        <TrackCard client:load id={track.id} title={track.data.title} coverColor={track.data.coverColor} duration={track.data.duration} featured={false} />
      ))}
    </div>
  </section>

  <!-- Timeline -->
  <section class="max-w-5xl mx-auto px-6 py-20">
    <h2 class="text-2xl font-bold mb-2 flex items-center gap-3">
      <span class="text-amber-400">♥</span> 时间线
    </h2>
    <p class="text-white/40 mb-12">一些值得记住的时刻。</p>

    <Timeline client:load events={
      timeline.map(t => ({
        id: t.id, date: t.data.date, title: t.data.title, description: t.data.description,
        icon: t.data.icon, linkedTrack: t.data.linkedTrack,
      }))
    } />
  </section>

  <footer class="max-w-5xl mx-auto px-6 py-12 border-t border-white/5 text-center">
    <p class="text-white/20 text-sm">© {new Date().getFullYear()} titi.work · 用 ♪ 与深夜制作</p>
    <div class="flex justify-center gap-6 mt-4">
      <a href="/rss.xml" class="text-white/30 hover:text-white/60 text-xs transition-colors">RSS</a>
      <a href="/zh/about" class="text-white/30 hover:text-white/60 text-xs transition-colors">关于</a>
    </div>
  </footer>
</BaseLayout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    document.querySelectorAll('.track-wrapper').forEach(wrapper => {
      const el = wrapper as HTMLElement;
      const btn = el.querySelector('button');
      if (!btn) return;
      btn.addEventListener('click', () => {
        window.dispatchEvent(new CustomEvent('play-track', {
          detail: {
            id: el.dataset.id!,
            title: el.dataset.title!,
            audioFile: el.dataset.file!,
            coverColor: el.dataset.cover!,
            duration: Number(el.dataset.duration),
          }
        }));
      });
    });
  });
</script>
